style.css       <-- :root {
  --accent: #f39200;
  --bg: #fff;
  --card-bg: #111;
  --text: #111;
}

body { font-family: 'Exo 2', sans-serif; background: var(--bg); color: var(--text); margin:0; }

.hero {
  height: 90vh;
  display:flex; flex-direction: column; justify-content: center; align-items: center;
  text-align: center;
  background: linear-gradient(to bottom, rgba(0,0,0,0.3), rgba(0,0,0,0.7)), url('https://i.ibb.co/jkxX9qKZ/719gq-RSscf-L-AC-UF1000-1000-QL80-FMwebp.png') center/cover no-repeat;
  color:white;
}

.cta-btn { padding:12px 35px; margin:5px; text-transform: uppercase; font-weight: 700; border-radius: 5px; transition:0.3s; }
.cta-buy { background: var(--accent); color:white; }
.cta-read { background:white; color:var(--text); }
.section { max-width:900px; margin:50px auto; padding:40px 20px; background: var(--card-bg); border-radius:15px; color:white; }
.fade-up { opacity:0; transform: translateY(30px); transition: all 1s ease; }
.fade-up.show { opacity:1; transform: translateY(0); }
.footer { text-align:center; margin:50px 0; color:#777; }
script.js       <-- // Fade-up scroll animation
const elements = document.querySelectorAll('.fade-up');
window.addEventListener('scroll', () => {
  elements.forEach(el => {
    const top = el.getBoundingClientRect().top;
    if(top < window.innerHeight - 50) el.classList.add('show');
  });
});
